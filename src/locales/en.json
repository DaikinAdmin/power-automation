      "item2": "Contact data (phone number, delivery address)",
      "item3": "Transaction data (order history, payments)",
      "item4": "Technical data (IP address, cookies, browser data)"
    },
    "s4": {
      "title": "4. Purpose of Data Processing",
      "intro": "Your personal data is processed for the following purposes:",
      "item1": "Processing orders and customer service",
      "item2": "Marketing communications (with your consent)",
      "item3": "Analysis and improvement of our services"
    },
    "s5": {
      "title": "5. Cookies",
      "body": "Our site uses cookies to ensure proper functionality, analyze traffic, and personalize content. You can manage cookie settings through your browser settings or via our consent panel."
    },
    "s6": {
      "title": "6. Data Sharing",
      "body": "We do not sell or share your personal data with third parties without your consent, except as required by law or necessary for service delivery (e.g., courier companies, payment operators)."
    },
    "s7": {
      "title": "7. Your Rights",
      "body": "You have the right to access your data, rectify it, erase it, restrict processing, data portability, and object to processing. To exercise your rights, contact us at the email address provided on the contact page."
    },
    "s8": {
      "title": "8. Contact",
      "body": "If you have any questions regarding this Privacy Policy or the processing of your personal data, please contact us via the form on the Contact page."
    }
